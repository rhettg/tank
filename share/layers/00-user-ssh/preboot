#!/usr/bin/env bash
set -euo pipefail

ensure_uv() {
    if command -v uv >/dev/null 2>&1; then
        return 0
    fi

    if command -v curl >/dev/null 2>&1; then
        curl -LsSf https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="$HOME/.local/bin" UV_NO_MODIFY_PATH=1 sh
    elif command -v wget >/dev/null 2>&1; then
        wget -qO- https://astral.sh/uv/install.sh | env UV_INSTALL_DIR="$HOME/.local/bin" UV_NO_MODIFY_PATH=1 sh
    else
        echo "Error: uv not found and neither curl nor wget is available" >&2
        exit 1
    fi

    export PATH="$HOME/.local/bin:$PATH"
}

script_path="$(mktemp)"
trap 'rm -f "$script_path"' EXIT

cat >"$script_path" <<'PY'
# /// script
# requires-python = ">=3.12"
# dependencies = ["pyyaml"]
# ///
import os
from pathlib import Path

import yaml


def get_env(name: str) -> str:
    value = os.environ.get(name)
    if not value:
        raise SystemExit(f"{name} is not set")
    return value


cloud_init_path = Path(get_env("TANK_CLOUD_INIT"))
username = get_env("USER")
home = Path(get_env("HOME"))

if not cloud_init_path.exists():
    raise SystemExit(f"TANK_CLOUD_INIT does not exist: {cloud_init_path}")

key_path = None
for candidate in (home / ".ssh/id_ed25519.pub", home / ".ssh/id_rsa.pub"):
    if candidate.exists():
        key_path = candidate
        break

if key_path is None:
    raise SystemExit("No SSH public key found at ~/.ssh/id_ed25519.pub or ~/.ssh/id_rsa.pub")

ssh_key = key_path.read_text().strip()

raw = cloud_init_path.read_text()
if raw.startswith("#cloud-config"):
    raw = raw.split("\n", 1)[1] if "\n" in raw else ""

data = yaml.safe_load(raw) if raw.strip() else {}
if data is None:
    data = {}

users = data.get("users")
if users is None:
    users = []
elif not isinstance(users, list):
    raise SystemExit("cloud-init 'users' must be a list")

existing = None
for user in users:
    if isinstance(user, dict) and user.get("name") == username:
        existing = user
        break

payload = {
    "name": username,
    "sudo": "ALL=(ALL) NOPASSWD:ALL",
    "shell": "/bin/bash",
    "ssh_authorized_keys": [ssh_key],
}

if existing is None:
    users.append(payload)
else:
    existing.update(payload)

data["users"] = users

serialized = yaml.safe_dump(data, sort_keys=False, default_flow_style=False)
cloud_init_path.write_text("#cloud-config\n" + serialized)
PY

ensure_uv
uv run --quiet --script "$script_path"
